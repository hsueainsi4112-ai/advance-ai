# Required env vars for the AI service.
# Copy this file to .env (gitignored) and fill in your local values.

# Absolute path to the repo root (where data/ and models/ live).
# On your machine, this is wherever you cloned the repo.
AI_DATA_ROOT=/absolute/path/to/advanced-ai

# Shared secret for /api/v1/admin/upload-model.
# Dev default is fine locally; production uses a random string via DESD's secrets manager.
AI_ADMIN_KEY=qwerty123
